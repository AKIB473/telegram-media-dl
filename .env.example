# ── Required ──────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ── Optional ──────────────────────────────────────────────────
# Comma-separated Telegram user IDs with admin access
# ADMIN_IDS=123456789,987654321

# Forward every download to this chat
# TARGET_CHAT=-1001234567890

# Where to save downloaded files
# DOWNLOAD_DIR=downloads

# File size limit in MB (Telegram max is 2000 MB for bots)
# MAX_FILE_SIZE_MB=1900

# Max simultaneous downloads
# MAX_CONCURRENT=3

# Rate limiting: N requests per window (seconds)
# RATE_LIMIT_COUNT=5
# RATE_LIMIT_WINDOW=3600

# Allow playlist downloads
# ALLOW_PLAYLISTS=false

# Show thumbnail before quality selection
# SEND_THUMBNAIL=true

# Per-download timeout in seconds
# DOWNLOAD_TIMEOUT=300

# yt-dlp retry count
# MAX_RETRIES=3

# SQLite database path
# DB_PATH=tmdl.db

# Logging level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Default audio quality in kbps
# DEFAULT_AUDIO_QUALITY=192

# Path to a cookies.txt file for age-restricted content
# COOKIE_FILE=cookies.txt
